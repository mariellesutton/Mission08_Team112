@using MissionTask = Mission08_Team112.Models.Task
@model MissionTask

@{
    ViewData["Title"] = "Add Task";
}

<h2 class="mb-4">Add Task</h2>

<form asp-action="Add" method="post">
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Task</label>
                <input asp-for="TaskName" class="form-control" />
                <span asp-validation-for="TaskName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Quadrant</label>
                <select asp-for="Quadrant" class="form-select">
                    <option value="">Select Quadrant</option>
                    <option value="1">Quadrant I - Urgent/Important</option>
                    <option value="2">Quadrant II - Important/Not Urgent</option>
                    <option value="3">Quadrant III - Urgent/Not Important</option>
                    <option value="4">Quadrant IV - Not Urgent/Not Important</option>
                </select>
                <span asp-validation-for="Quadrant" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-select">
                    <option value="">Select Category</option>
                    @foreach (var c in ViewBag.Categories)
                    {
                        <option value="@c.CategoryId">@c.CategoryName</option>
                    }
                </select>
            </div>
            <div class="form-check mb-3">
                <input asp-for="Completed" class="form-check-input" />
                <label class="form-check-label">Completed</label>
            </div>
            <button type="submit" class="btn btn-primary">Save Task</button>
            <a class="btn btn-secondary" asp-controller="Task" asp-action="Index">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}